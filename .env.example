# Supabase — copy to .env.local and fill from Project Settings → API
# Required for the contact form; optional for testimonials/projects CMS data.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Auth: visitors use the anon key only. Authenticated policies allow CMS writes.
# After setting variables, run supabase/migrations/001_initial_schema.sql then seed.sql.
