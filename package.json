{
  "name": "elikplim-portfolio",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "seed:generate": "node scripts/generate-seed.mjs",
    "media:pull": "git lfs install && git lfs pull",
    "supabase:setup": "bash scripts/setup-supabase.sh",
    "supabase:seed-cms": "supabase db query --file supabase/seed-cms.sql --linked",
    "supabase:migrate-cms": "supabase db query --file supabase/migrate-portfolio-to-cms.sql --linked",
    "supabase:db-push": "supabase db push --linked",
    "vercel:env": "bash scripts/sync-vercel-env.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}
